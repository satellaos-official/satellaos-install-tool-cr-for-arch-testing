	<action>
		<icon>accessories-text-editor</icon>
		<name>Edit with Nano</name>
		<submenu></submenu>
		<unique-id>1776434074190285-14</unique-id>
		<command>xfce4-terminal --hold --command=&quot;nano %f&quot;</command>
		<description>Edit file with nano in terminal</description>
		<range>*</range>
		<patterns>*</patterns>
		<other-files/>
